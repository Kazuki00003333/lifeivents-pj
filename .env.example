# ===========================================
# 環境変数サンプル（このファイルをコピーして .env を作成）
# 実際のキーは .env に記載し、.env は Git にコミットしないこと
# ===========================================

# --- クライアント（Expo / ブラウザ）に露出する変数 ---
# EXPO_PUBLIC_ プレフィックスが付いたものだけがクライアントにバンドルされます。
# 秘密鍵（Service Role Key や API Key）はここに書かないでください。

# Supabase（匿名キーのみ。RLS で権限を制御）
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 招待リンクのベースURL（本番では Vercel のドメインなど）
EXPO_PUBLIC_INVITE_BASE_URL=https://your-app.vercel.app

# AI API のベースURL（未設定の場合は EXPO_PUBLIC_INVITE_BASE_URL を使用）
# 例: https://your-app.vercel.app （Vercel デプロイ先と同じドメイン）
# EXPO_PUBLIC_API_URL=https://your-app.vercel.app

# --- サーバー専用（Vercel の Environment Variables に設定） ---
# 以下の変数はクライアントコードでは参照せず、Vercel の API Routes / Serverless のみで使用。
# 実際のキーは .env に記載せず、Vercel Dashboard → Settings → Environment Variables で設定してください。

# Supabase（API で JWT 検証・ai_usage 更新に使用）
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AI プロバイダー（ユーザーが渡した API Key を Vercel の環境変数に設定して使用）
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
